# ── Database ──────────────────────────────────────────
# REQUIRED — container fails to start without it.
POSTGRES_PASSWORD=change_this_to_a_real_password
DATABASE_URL=postgresql://postgres:change_this_to_a_real_password@db:5432/orbis_finai

# ── API Auth ──────────────────────────────────────────
# Set for production (frontend needs NEXT_PUBLIC_API_KEY with same value).
# Leave empty to disable auth (local dev only, NOT production).
API_KEY=

# Frontend env (baked at build time):
# NEXT_PUBLIC_API_URL=https://your-api-url
# NEXT_PUBLIC_API_KEY=same_as_API_KEY

# ── Destructive reset guard ────────────────────────────
# Allow admin reset endpoints without API_KEY (local only, NEVER prod).
# In production, set API_KEY and use X-Confirm-Reset: yes header.
ALLOW_DESTRUCTIVE_RESET=

# ── Fernet key for LLM key encryption ──────────────────
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=

# ── LLM Provider Keys (at least one required) ──────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
NVIDIA_API_KEY=

# ── Webhook notifications (optional) ───────────────────
# Slack/Discord compatible POST URL for report done events.
WEBHOOK_URL=

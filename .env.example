# ── Database ──────────────────────────────────────────
# REQUIRED — container fails to start without it.
POSTGRES_PASSWORD=change_this_to_a_real_password
DATABASE_URL=postgresql://postgres:change_this_to_a_real_password@db:5432/orbis_finai

# ── API Auth (optional — leave empty to disable) ────
API_KEY=

# ── Fernet key for LLM key encryption (optional) ────
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=

# ── LLM Provider Keys (at least one required) ───────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
NVIDIA_API_KEY=
